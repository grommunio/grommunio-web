msgctxt "mail.previewpanel"
msgid ""
"This meeting is not in the Calendar; it may have been moved or deleted."
msgstr "این جلسه در تقویم نیست. ممکن است منتقل یا حذف شده باشد."

msgctxt "mail.previewpanel"
msgid ""
"This meeting request was updated after this message was sent. You should "
"open the latest update or open the item from the calendar."
msgstr ""
"این درخواست جلسه پس از ارسال این پیام به‌روزرسانی شد. شما باید آخرین "
"به‌روزرسانی را باز کنید یا این آیتم را از تقویم باز کنید."

msgctxt "mail.previewpanel"
msgid "As the meeting organizer, you do not need to respond to the meeting"
msgstr "به عنوان سازمان دهنده جلسه، نیازی به پاسخگویی به جلسه ندارید"

msgctxt "mail.previewpanel"
msgid "The meeting was updated after the attendee sent this response"
msgstr "جلسه پس از ارسال این پاسخ توسط حاضرین به روز شد"

msgctxt "mail.previewpanel"
msgid "This appointment occurs in the past."
msgstr "این قرار در گذشته اتفاق افتاده است."

