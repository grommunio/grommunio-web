"The uploaded file exceeds the upload_max_filesize directive in php.ini."
msgstr "فایل آپلود شده از دستور upload_max_filesize در php.ini بیشتر است."

msgid ""
"The uploaded file exceeds the MAX_FILE_SIZE directive that was specified in "
"the HTML form."
msgstr ""
"فایل بارگذاری‌شده از مقدار مجاز MAX_FILE_SIZE که در فرم HTML مشخص شده بود، "
"بزرگ‌تر است."

msgid "The uploaded file was only partially uploaded."
msgstr "فایل آپلود شده فقط تا حدی آپلود شد."

msgid "No file was uploaded. ."
msgstr "هیچ فایلی آپلود نشد ."

msgid "Missing a temporary folder."
msgstr "یک پوشه موقت از دست رفته است."

msgid "Failed to write file to disk."
msgstr "نوشتن فایل روی دیسک انجام نشد."

msgid ""
"A PHP extension stopped the file upload. PHP does not provide a way to "
"ascertain which extension caused the file upload to stop; examining the list"
" of loaded extensions with phpinfo() may help."
msgstr ""
"یک افزونهٔ PHP بارگذاری فایل را متوقف کرد. PHP راهی برای تشخیص اینکه کدام "
"افزونه باعث توقف بارگذاری فایل شده است ارائه نمی‌دهد؛ بررسی فهرست افزونه‌های"
" بارگذاری‌شده با phpinfo() ممکن است کمک کند."

msgid "There is no contact found in this file."
msgstr "هیچ مخاطبی در این فایل یافت نشد."

msgid ""
"grommunio Web does not support importing multiple VCF with this version."
msgstr ""
"grommunio Web در این نسخه از وارد کردن چندین فایل VCF پشتیبانی نمی‌کند."

msgid ""
"grommunio Web does not support importing multiple ICS with this version."
msgstr ""
"grommunio Web در این نسخه از وارد کردن چندین فایل ICS پشتیبانی نمی‌کند."

msgid "GB"
msgstr "گیگابایت"

msgid "MB"
msgstr "مگابایت"

msgid "KB"
msgstr "کیلوبایت"

msgid "B"
msgstr "ب"

msgid "The maximum stack depth has been exceeded"
msgstr "از حداکثر عمق پشته فراتر رفته است"

msgid "Control character error, possibly incorrectly encoded"
msgstr "خطای کاراکتر کنترل، احتمالاً به اشتباه کدگذاری شده است"

msgid "Invalid or malformed JSON"
msgstr "JSON نامعتبر یا نادرست است"

msgid "Syntax error"
msgstr "خطای نحوی"

msgid "Malformed UTF-8 characters, possibly incorrectly encoded"
msgstr "نویسه‌های UTF-8 نادرست، احتمالاً به اشتباه کدگذاری شده‌اند"

#, php-format
msgid "Some problem encountered when encoding/decoding JSON data: - %s"
msgstr "مشکلی که هنگام رمزگذاری/رمزگشایی داده‌های JSON وجود دارد: -%s"
